# Copy this file to .env and fill in real values. NEVER commit the real .env.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# Local dev port (Render provides its own PORT in production — do not set it there)
PORT=5000

# Long random string used to sign JWTs (generate one, keep it secret)
JWT_SECRET=replace_with_a_long_random_secret

# "development" locally, "production" on Render
NODE_ENV=development

# Gmail SMTP credentials (used by nodemailer to send verification/reset emails)
# GMAIL_APP_PASSWORD is a 16-char App Password (NOT your normal password):
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification enabled)
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Base URL of the frontend (used to build password-reset links in emails)
# Local: http://localhost:5173   |   Production: https://your-app.onrender.com
CLIENT_URL=http://localhost:5173
